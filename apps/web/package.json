{
  "name": "neonbinder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "module": "./dist-design-system/index.es.js",
  "types": "./dist-design-system/index.d.ts",
  "scripts": {
    "dev": "vite",
    "dev:backend": "./dev-backend.sh",
    "dev:all": "concurrently \"vite\" \"./dev-backend.sh\"",
    "dev:backend:tunnel": "./dev-backend-tunnel.sh",
    "env:browser": "npx convex env set NEONBINDER_BROWSER_URL",
    "tunnel": "cloudflared tunnel --url http://localhost:8080",
    "predev:all": "./setup-env.sh",
    "build": "vite build",
    "build:design-system": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json && mkdir -p .design-sync/.cache && printf 'import \"../../app/globals.css\";\\n' > .design-sync/.cache/css-entry.ts && vite build --config vite.lib.css.config.ts",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "link-deps": "./link-deps.sh",
    "builder": "npx builder.io@latest launch --app --serverUrl http://localhost:3000",
    "setup:e2e": "./setup-maestro.sh",
    "setup:e2e:signin": "./setup-maestro-signin.sh",
    "test:e2e:check": "./check-e2e-env.sh",
    "test:e2e": "PATH=$HOME/.maestro/bin:$PATH ./run-e2e-smoke.sh",
    "test:e2e:signin": "PATH=$HOME/.maestro/bin:$PATH maestro test --platform web --config .maestro/config.yaml -e APP_URL=${APP_URL:-http://localhost:3000} .maestro/flows/auth/sign-in.yaml",
    "test:e2e:dashboard": "PATH=$HOME/.maestro/bin:$PATH maestro test --platform web --config .maestro/config.yaml -e APP_URL=${APP_URL:-http://localhost:3000} .maestro/flows/dashboard/view-collection.yaml",
    "test:e2e:single": "maestro test --platform web --config .maestro/config.yaml -e APP_URL=${APP_URL:-http://localhost:3000} -e TEST_USERNAME=${TEST_USERNAME:-neontester_$(date +%s)}",
    "test:e2e:smoke": "PATH=$HOME/.maestro/bin:$PATH ./run-e2e-smoke.sh smoke",
    "test:e2e:regression": "PATH=$HOME/.maestro/bin:$PATH ./run-e2e-smoke.sh regression",
    "test:e2e:pick": "PATH=$HOME/.maestro/bin:$PATH ./run-e2e-smoke.sh",
    "test:e2e:plan": "MAESTRO_PLAN_ONLY=1 PATH=$HOME/.maestro/bin:$PATH ./run-e2e-smoke.sh",
    "test:e2e:ci": "PATH=$HOME/.maestro/bin:$PATH ./run-e2e-smoke.sh smoke",
    "test:e2e:like-ci": "./run-e2e-like-ci.sh",
    "e2e:local": "./e2e-local-stack.sh",
    "e2e:local:fresh": "./e2e-local-stack.sh --seed",
    "e2e:local:seed": "./e2e-seed.sh",
    "postinstall": "husky install"
  },
  "dependencies": {
    "@clerk/backend": "^3.12.0",
    "@clerk/clerk-react": "^5.61.9",
    "@convex-dev/auth": "^0.0.94",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-cloud/storage": "^7.21.0",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/themes": "^3.3.0",
    "@sentry/react": "^10.67.0",
    "@sentry/vite-plugin": "^5.4.0",
    "@types/crypto-js": "^4.2.2",
    "@vercel/blob": "^2.6.1",
    "axios": "^1.18.1",
    "convex": "^1.42.3",
    "convex-helpers": "^0.1.120",
    "crypto-js": "^4.2.0",
    "google-auth-library": "^10.9.0",
    "posthog-js": "^1.406.2",
    "posthog-node": "^5.46.0",
    "qr-scanner": "^1.4.2",
    "qrcode-generator": "^2.0.4",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-router": "^8.3.0",
    "react-virtuoso": "^4.18.11"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/vite": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/node": "^5.8.26",
    "@vitejs/plugin-react": "^6.0.4",
    "concurrently": "^10.0.3",
    "convex-test": "^0.0.54",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.11.0",
    "husky": "^9.1.7",
    "localtunnel": "^2.0.2",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.1.11",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vite-plugin-mkcert": "^2.1.0",
    "vitest": "^4.1.10"
  }
}

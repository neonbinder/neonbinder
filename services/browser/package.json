{
  "name": "neonbinder_browser",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx dotenv-cli -- ts-node src/index.ts",
    "dev:login": "gcloud auth application-default login --impersonate-service-account=neonbinder-browser-runtime@neonbinder-dev-io.iam.gserviceaccount.com",
    "deploy": "gcloud builds submit --config cloudbuild.yaml .",
    "test": "node --test tests/base-adapter.test.mjs tests/bsc-adapter.test.mjs tests/sportlots-adapter.test.mjs tests/credentials-routes.test.mjs tests/login-diagnostic.test.mjs",
    "test:prod-gate": "node --test tests/integration/*.test.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google-cloud/secret-manager": "^6.2.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "puppeteer": "^25.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/node": "^26.0.1",
    "dotenv-cli": "^11.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "ws": "^8.21.0",
    "js-yaml": "^4.3.0"
  }
}
